APOTHECA ?= .

CC      ?= cc
CFLAGS  ?= -Wall -Wextra -pedantic -std=c99 -O2 -I$(APOTHECA)/ison -I$(APOTHECA)/phantasma
LDFLAGS = -lm `cat $(APOTHECA)/phantasma/nexus_phantasma`

LIBISON = $(APOTHECA)/ison/libison.a
LIBPHANTASMA = $(APOTHECA)/phantasma/libphantasma.a

ASTRA = sidus.o campus.o instrumentum.o planeta.o aspectus.o perceptus.o
CAPITA = sidus.h campus.h instrumentum.h planeta.h aspectus.h perceptus.h color.h vectores.h

CAELAE = caelae/terra.isonl caelae/hubble.isonl caelae/jwst.isonl \
         caelae/nuclei.isonl caelae/vacuum.isonl caelae/mortis.isonl \
         caelae/binarium.isonl

omnia: torus_planus torus_animare torus_specta astra_proba caele redde astra_animare proba planeta_proba caelae_proba

omnia: $(NOMEN)

caelae: $(CAELAE)

caelae/terra.isonl: campi/terra.ison caele
	./caele campi/terra.ison > caelae/terra.isonl

caelae/hubble.isonl: campi/hubble.ison caele
	./caele campi/hubble.ison > caelae/hubble.isonl

caelae/jwst.isonl: campi/jwst.ison caele
	./caele campi/jwst.ison > caelae/jwst.isonl

caelae/nuclei.isonl: campi/nuclei.ison caele
	./caele campi/nuclei.ison > caelae/nuclei.isonl

caelae/vacuum.isonl: campi/vacuum.ison caele
	./caele campi/vacuum.ison > caelae/vacuum.isonl

caelae/mortis.isonl: campi/mortis.ison caele
	./caele campi/mortis.ison > caelae/mortis.isonl

caelae/binarium.isonl: campi/binarium.ison caele
	./caele campi/binarium.ison > caelae/binarium.isonl

lude: torus_specta caelae/terra.isonl
	./torus_specta

para:
	git submodule update --init ison phantasma
	$(FACE) -C ison
	$(FACE) -C phantasma

expara:
	git submodule deinit -f ison phantasma

$(LIBISON):
        $(FACE) -C $(APOTHECA)/ison

$(LIBPHANTASMA):
	$(FACE) -C $(APOTHECA)/phantasma

pictura.o: pictura.c $(CAPITA)
	$(CC) $(CFLAGS) -c -o pictura.o pictura.c

helvea.o: helvea.c $(CAPITA)
	$(CC) $(CFLAGS) -c -o helvea.o helvea.c

sidus.o: sidus.c $(CAPITA)
	$(CC) $(CFLAGS) -c -o sidus.o sidus.c

campus.o: campus.c $(CAPITA)
	$(CC) $(CFLAGS) -c -o campus.o campus.c

instrumentum.o: instrumentum.c $(CAPITA)
	$(CC) $(CFLAGS) -c -o instrumentum.o instrumentum.c

aspectus.o: aspectus.c $(CAPITA)
	$(CC) $(CFLAGS) -c -o aspectus.o aspectus.c

perceptus.o: perceptus.c $(CAPITA)
	$(CC) $(CFLAGS) -c -o perceptus.o perceptus.c

planeta.o: planeta.c $(CAPITA)
	$(CC) $(CFLAGS) -c -o planeta.o planeta.c

torus_planus: torus_planus.c pictura.o helvea.o $(ASTRA) $(LIBISON) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ torus_planus.c pictura.o helvea.o $(ASTRA) $(LIBISON) $(LDFLAGS)

torus_animare: torus_animare.c pictura.o helvea.o $(ASTRA) $(LIBISON) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ torus_animare.c pictura.o helvea.o $(ASTRA) $(LIBISON) $(LDFLAGS)

torus_specta: torus_specta.c pictura.o helvea.o $(ASTRA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ torus_specta.c pictura.o helvea.o $(ASTRA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

proba: proba.c $(CAPITA)
	$(CC) $(CFLAGS) -o $@ proba.c -lm

astra_proba: astra_proba.c $(ASTRA) $(LIBISON) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ astra_proba.c $(ASTRA) $(LIBISON) $(LDFLAGS)

planeta_proba: planeta_proba.c $(ASTRA) $(LIBISON) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ planeta_proba.c $(ASTRA) $(LIBISON) $(LDFLAGS)

caelae_proba: caelae_proba.c $(ASTRA) $(LIBISON) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ caelae_proba.c $(ASTRA) $(LIBISON) $(LDFLAGS)

caele: caele.c $(ASTRA) $(LIBISON) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ caele.c $(ASTRA) $(LIBISON) $(LDFLAGS)

redde: redde.c $(ASTRA) $(LIBISON) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ redde.c $(ASTRA) $(LIBISON) $(LDFLAGS)

astra_animare: astra_animare.c $(ASTRA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ astra_animare.c $(ASTRA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

purga:
	rm -f torus_planus torus_animare torus_specta astra_proba planeta_proba caelae_proba caele redde astra_animare proba
	rm -f pictura.o helvea.o sidus.o campus.o instrumentum.o planeta.o aspectus.o perceptus.o
	rm -f caelae/*.ppm caelae/*.isonl

.PHONY: omnia purga caelae lude
