PREFIX = /opt/apotheca

CC      ?= cc
AR      ?= ar
CFLAGS  ?= -Wall -Wextra -pedantic -std=c99 -O2 -I$(PREFIX)/include
LDFLAGS = -lm `cat $(PREFIX)/lib/nexus_phantasma`

LIBISON = $(PREFIX)/lib/libison.a
LIBPHANTASMA = $(PREFIX)/lib/libphantasma.a
LIBDELPHI = $(PREFIX)/lib/libdelphi.a
LIBCRISPUS = $(PREFIX)/lib/libcrispus.a
LIBPROPLASMA = $(PREFIX)/lib/libproplasma.a

OBJECTA = pictura.o helvea.o campus.o instrumentum.o caela.o universalis.o formula.o designatio.o orbita.o permutationes.o locus.o \
          aspectus.o perceptus.o \
          tesserae/sidus.o tesserae/planeta.o tesserae/visio.o \
          tesserae/sidera/nanum_album.o tesserae/sidera/sequentia.o \
          tesserae/sidera/gigas_rubrum.o tesserae/sidera/supergigas.o \
          tesserae/sidera/neutronium.o tesserae/sidera/crystallinum.o \
          tesserae/sidera/magnetar.o tesserae/sidera/galaxia.o \
          tesserae/sidera/vagans.o \
          tesserae/planetae/saxosum.o tesserae/planetae/gaseosum.o \
          tesserae/planetae/glaciale.o tesserae/planetae/parvum.o \
          tesserae/planetae/sol.o tesserae/planetae/nebula.o \
          tesserae/planetae/simulacrum.o \
          tesserae/visiones/torus.o tesserae/visiones/navis.o \
          tesserae/visiones/zeppelinus.o
BIBLIOTHECA = libsqrt.a
CAPITA = campus.h instrumentum.h aspectus.h caela.h universalis.h formula.h designatio.h orbita.h permutationes.h locus.h \
         perceptus.h color.h vectores.h pictura.h helvea.h bessel.h \
         tesserae/sidus.h tesserae/sidus_communia.h \
         tesserae/planeta.h tesserae/planeta_communia.h \
         tesserae/visio.h tesserae/visio_communia.h \
         tessera.h tessella.h

CAELAE = caelae/terra.ison caelae/hubble.ison caelae/jwst.ison \
         caelae/nuclei.ison caelae/vacuum.ison caelae/mortis.ison \
         caelae/binarium.ison

omnia: torus_planus torus_animare torus_specta caele genera redde astra_animare gen_universalis universalis_gif proba_planeta proba_caelae proba_visio colloquium

omnia: $(NOMEN)

caelae: $(CAELAE)

caelae/terra.ison: formulae/terra.ison caele
	./caele formulae/terra.ison > caelae/terra.ison

caelae/hubble.ison: formulae/hubble.ison caele
	./caele formulae/hubble.ison > caelae/hubble.ison

caelae/jwst.ison: formulae/jwst.ison caele
	./caele formulae/jwst.ison > caelae/jwst.ison

caelae/nuclei.ison: formulae/nuclei.ison caele
	./caele formulae/nuclei.ison > caelae/nuclei.ison

caelae/vacuum.ison: formulae/vacuum.ison caele
	./caele formulae/vacuum.ison > caelae/vacuum.ison

caelae/mortis.ison: formulae/mortis.ison caele
	./caele formulae/mortis.ison > caelae/mortis.ison

caelae/binarium.ison: formulae/binarium.ison caele
	./caele formulae/binarium.ison > caelae/binarium.ison

lude: torus_specta
	./torus_specta

# objecta

%.o: %.c $(CAPITA)
	$(CC) $(CFLAGS) -c -o $@ $<

# bibliotheca

libsqrt.a: $(OBJECTA)
	$(AR) rcs $@ $(OBJECTA)

# programmata

torus_planus: torus_planus.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ torus_planus.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

torus_animare: torus_animare.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ torus_animare.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

torus_specta: torus_specta.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ torus_specta.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

proba: proba_prima proba_astra proba_planeta proba_caelae proba_visio proba_permutationes
	./proba_prima
	./proba_caelae
	./proba_astra
	./proba_planeta
	./proba_visio
	./proba_permutationes
	./proba_schemata.sh

proba_prima: proba_prima.c $(CAPITA)
	$(CC) $(CFLAGS) -o $@ proba_prima.c -lm

proba_astra: proba_astra.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ proba_astra.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

proba_planeta: proba_planeta.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ proba_planeta.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

proba_caelae: proba_caelae.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ proba_caelae.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

proba_visio: proba_visio.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ proba_visio.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

proba_permutationes: proba_permutationes.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ proba_permutationes.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

caele: caele.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ caele.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

genera: genera.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ genera.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

gen_universalis: gen_universalis.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ gen_universalis.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

universalis_gif: universalis_gif.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ universalis_gif.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

redde: redde.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ redde.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

astra_animare: astra_animare.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ astra_animare.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

colloquium: colloquium.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LIBDELPHI) $(LIBCRISPUS) $(LIBPROPLASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ colloquium.c $(BIBLIOTHECA) $(LIBDELPHI) $(LIBCRISPUS) $(LIBPROPLASMA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

colloca: omnia
	install -d $(PREFIX)/bin $(PREFIX)/lib $(PREFIX)/include/sqrt/tesserae
	install -m 755 torus_planus torus_animare torus_specta caele genera redde astra_animare gen_universalis universalis_gif $(PREFIX)/bin/
	install -m 644 $(BIBLIOTHECA) $(PREFIX)/lib/
	install -m 644 campus.h instrumentum.h aspectus.h perceptus.h color.h vectores.h pictura.h helvea.h bessel.h tessera.h tessella.h $(PREFIX)/include/sqrt/
	install -m 644 tesserae/sidus.h tesserae/planeta.h tesserae/visio.h $(PREFIX)/include/sqrt/tesserae/

purga:
	rm -f torus_planus torus_animare torus_specta proba_astra proba_planeta proba_caelae proba_visio proba_permutationes caele genera redde astra_animare gen_universalis universalis_gif proba_prima
	rm -f $(OBJECTA) $(BIBLIOTHECA)
	rm -f caelae/*.ppm caelae/*.ison

linte:
	insinulint -c *.c *.h

.PHONY: omnia colloca purga proba caelae lude linte
