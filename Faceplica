PREFIX = /opt/apotheca

CC      ?= cc
AR      ?= ar
CFLAGS  ?= -Wall -Wextra -pedantic -std=c99 -O2 -I$(PREFIX)/include/ison -I$(PREFIX)/include/phantasma
LDFLAGS = -lm `cat $(PREFIX)/lib/nexus_phantasma`

LIBISON = $(PREFIX)/lib/libison.a
LIBPHANTASMA = $(PREFIX)/lib/libphantasma.a

OBJECTA = pictura.o helvea.o campus.o instrumentum.o \
          aspectus.o perceptus.o \
          tesserae/sidus.o tesserae/planeta.o tesserae/visio.o
BIBLIOTHECA = libsqrt.a
CAPITA = campus.h instrumentum.h aspectus.h \
         perceptus.h color.h vectores.h pictura.h helvea.h bessel.h \
         tesserae/sidus.h tesserae/planeta.h tesserae/visio.h \
         tessera.h tessella.h

CAELAE = caelae/terra.isonl caelae/hubble.isonl caelae/jwst.isonl \
         caelae/nuclei.isonl caelae/vacuum.isonl caelae/mortis.isonl \
         caelae/binarium.isonl

omnia: torus_planus torus_animare torus_specta proba_astra caele genera redde astra_animare proba proba_planeta proba_caelae proba_visio

omnia: $(NOMEN)

caelae: $(CAELAE)

caelae/terra.isonl: campi/terra.ison caele
	./caele campi/terra.ison > caelae/terra.isonl

caelae/hubble.isonl: campi/hubble.ison caele
	./caele campi/hubble.ison > caelae/hubble.isonl

caelae/jwst.isonl: campi/jwst.ison caele
	./caele campi/jwst.ison > caelae/jwst.isonl

caelae/nuclei.isonl: campi/nuclei.ison caele
	./caele campi/nuclei.ison > caelae/nuclei.isonl

caelae/vacuum.isonl: campi/vacuum.ison caele
	./caele campi/vacuum.ison > caelae/vacuum.isonl

caelae/mortis.isonl: campi/mortis.ison caele
	./caele campi/mortis.ison > caelae/mortis.isonl

caelae/binarium.isonl: campi/binarium.ison caele
	./caele campi/binarium.ison > caelae/binarium.isonl

lude: torus_specta caelae/terra.isonl
	./torus_specta

# objecta

%.o: %.c $(CAPITA)
	$(CC) $(CFLAGS) -c -o $@ $<

# bibliotheca

libsqrt.a: $(OBJECTA)
	$(AR) rcs $@ $(OBJECTA)

# programmata

torus_planus: torus_planus.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ torus_planus.c $(BIBLIOTHECA) $(LIBISON) $(LDFLAGS)

torus_animare: torus_animare.c $(BIBLIOTHECA) $(LIBISON) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ torus_animare.c $(BIBLIOTHECA) $(LIBISON) $(LDFLAGS)

torus_specta: torus_specta.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ torus_specta.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

proba: proba_prima proba_astra proba_planeta proba_caelae proba_visio
	./proba_prima
	./proba_caelae
	./proba_astra
	./proba_planeta
	./proba_visio

proba_prima: proba_prima.c $(CAPITA)
	$(CC) $(CFLAGS) -o $@ proba_prima.c -lm

proba_astra: proba_astra.c $(BIBLIOTHECA) $(LIBISON) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ proba_astra.c $(BIBLIOTHECA) $(LIBISON) $(LDFLAGS)

proba_planeta: proba_planeta.c $(BIBLIOTHECA) $(LIBISON) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ proba_planeta.c $(BIBLIOTHECA) $(LIBISON) $(LDFLAGS)

proba_caelae: proba_caelae.c $(BIBLIOTHECA) $(LIBISON) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ proba_caelae.c $(BIBLIOTHECA) $(LIBISON) $(LDFLAGS)

proba_visio: proba_visio.c $(BIBLIOTHECA) $(LIBISON) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ proba_visio.c $(BIBLIOTHECA) $(LIBISON) $(LDFLAGS)

caele: caele.c $(BIBLIOTHECA) $(LIBISON) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ caele.c $(BIBLIOTHECA) $(LIBISON) $(LDFLAGS)

genera: genera.c $(LIBISON)
	$(CC) $(CFLAGS) -o $@ genera.c $(LIBISON) -lm

redde: redde.c $(BIBLIOTHECA) $(LIBISON) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ redde.c $(BIBLIOTHECA) $(LIBISON) $(LDFLAGS)

astra_animare: astra_animare.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(CAPITA)
	$(CC) $(CFLAGS) -o $@ astra_animare.c $(BIBLIOTHECA) $(LIBISON) $(LIBPHANTASMA) $(LDFLAGS)

colloca: omnia
	install -d $(PREFIX)/bin $(PREFIX)/lib $(PREFIX)/include/sqrt/tesserae
	install -m 755 torus_planus torus_animare torus_specta caele genera redde astra_animare $(PREFIX)/bin/
	install -m 644 $(BIBLIOTHECA) $(PREFIX)/lib/
	install -m 644 campus.h instrumentum.h aspectus.h perceptus.h color.h vectores.h pictura.h helvea.h bessel.h tessera.h tessella.h $(PREFIX)/include/sqrt/
	install -m 644 tesserae/sidus.h tesserae/planeta.h tesserae/visio.h $(PREFIX)/include/sqrt/tesserae/

purga:
	rm -f torus_planus torus_animare torus_specta proba_astra proba_planeta proba_caelae proba_visio caele genera redde astra_animare proba_prima
	rm -f $(OBJECTA) $(BIBLIOTHECA)
	rm -f caelae/*.ppm caelae/*.isonl

linte:
	insinulint -c *.c *.h

.PHONY: omnia colloca purga proba caelae lude linte
